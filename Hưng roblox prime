-- FUNCTION LOADSCRIPT ANTI ERROR
local function LoadScript(url)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)

    if success then
        loadstring(result)()
    else
        warn("Không load được script:", url)
    end
end

